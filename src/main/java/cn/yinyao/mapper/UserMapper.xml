<?xml version="1.0" encoding="UTF-8" ?>  
<!DOCTYPE mapper PUBLIC "-//ibatis.apache.org//DTD Mapper 3.0//EN"      
 "http://ibatis.apache.org/dtd/ibatis-3-mapper.dtd">

<mapper namespace="cn.yinyao.dao.UserDao">
  <resultMap id="yin" type="cn.yinyao.entity.User">
        <id column="id" jdbcType="INTEGER" property="id"/>
        <result column="password" jdbcType="VARCHAR" property="password"/>
        <result column="username" jdbcType="VARCHAR" property="username"/>
        <result column="address" jdbcType="VARCHAR" property="address"/>
        <result column="createtime" jdbcType="TIMESTAMP" property="createtime"/>
        <result column="updatetime" jdbcType="TIMESTAMP" property="updatetime"/>
       
    </resultMap>
  <insert id="save" parameterType="map">
    insert into practice(username,password,address) values(#{username},#{password},NULL);
  </insert>
  <delete id="delete" parameterType="java.lang.Integer">
    delete from practice where id=#{id};
  </delete>
 <update id="update" parameterType="map">
  update practice set username=#{username},password=#{password},address=#{address} where id=#{id};
  </update>
  <delete id="deleteAll" parameterType="java.util.ArrayList">
    delete from practice where id in 
    <foreach collection="array" item="ids" open="(" close=")" separator="," index="index">#{ids}</foreach>;
  </delete>
  <insert id="saveAll" parameterType="list">
    insert into practice(username,password,address) 
    values 
    <foreach collection="list" separator=","  item="list">(#{list.username},#{list.password},#{list.address})</foreach>
  </insert>
  
  <select id="getPage" parameterType="java.util.HashMap" resultType="cn.yinyao.entity.User" resultMap="yin">
  select * from practice limit #{pageIndex},#{pageSize};
  </select>
  
  
</mapper>


